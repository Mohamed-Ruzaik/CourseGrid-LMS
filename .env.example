POSTGRES_DB=coursegrid
POSTGRES_USER=coursegrid_user
POSTGRES_PASSWORD=coursegrid_password

# Local backend connection string for running FastAPI directly on the host.
DATABASE_URL=postgresql://coursegrid_user:coursegrid_password@localhost:5432/coursegrid

APP_VERSION=0.1.0
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

JWT_SECRET_KEY=change-this-local-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Demo accounts created by: docker compose exec backend python -m app.seed_demo
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_INSTRUCTOR_EMAIL=instructor@example.com
DEMO_STUDENT_EMAIL=student@example.com
DEMO_PASSWORD=password123
